---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

type Lang = "zh" | "en";

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
  /** 是否加载 mermaid 客户端渲染 */
  withMermaid?: boolean;
}

const t = {
  zh: {
    brandTag: "A2A Workspace",
    nav: [
      ["#features", "特性"],
      ["#federation", "联邦"],
      ["#proactive", "主动出击"],
      ["#architecture", "架构"],
      ["#cli-ref", "CLI"],
      ["#quickstart", "快速开始"],
      ["/docs/", "文档"],
      ["/deck/", "幻灯片"],
    ],
    langSwitch: "EN",
    langSwitchHref: "/en/",
  },
  en: {
    brandTag: "A2A Workspace",
    nav: [
      ["/en/#features", "Features"],
      ["/en/#federation", "Federation"],
      ["/en/#proactive", "Proactive"],
      ["/en/#architecture", "Architecture"],
      ["/en/#cli-ref", "CLI"],
      ["/en/#quickstart", "Quick Start"],
      ["/en/docs/", "Docs"],
      ["/deck/", "Slides (中文)"],
    ],
    langSwitch: "中文",
    langSwitchHref: "/",
  },
};

const {
  title = "Rotom · Digital Employee Mesh",
  description = "A centralized digital-employee collaboration network. Master relays + Executor claims + rotom CLI — wraps claude / codex / hermes / openclaw into collaborating digital employees.",
  lang = "zh",
  withMermaid = false,
} = Astro.props;

const tr = t[lang];
const htmlLang = lang === "zh" ? "zh-CN" : "en";
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/rotom.jpeg" />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body>
    <nav class="nav">
      <div class="wrap nav__inner">
        <a href={lang === "zh" ? "/" : "/en/"} class="brand">
          <img src="/rotom.jpeg" alt="Rotom" class="brand__logo" />
          <span class="brand__name">Rotom</span>
          <span class="brand__tag">{tr.brandTag}</span>
        </a>
        <div class="nav__links">
          {tr.nav.map(([href, label]) => (
            <a href={href}>{label}</a>
          ))}
          <a href={tr.langSwitchHref} class="nav__lang" aria-label="Switch language">{tr.langSwitch}</a>
          <a href="https://code.alipay.com/cattery/rotom" class="nav__cta">GitHub</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <Footer lang={lang} />

    {withMermaid && (
      <script type="module">
        import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs";
        mermaid.initialize({
          startOnLoad: false,
          theme: "dark",
          themeVariables: {
            primaryColor: "#1a2244",
            primaryTextColor: "#e8edf7",
            primaryBorderColor: "#7c9cff",
            lineColor: "#9aa7c7",
            secondaryColor: "#131a32",
            tertiaryColor: "#0a0f1f",
            fontFamily: "ui-monospace, SF Mono, Menlo, Consolas, monospace",
          },
          flowchart: { htmlLabels: true, curve: "basis" },
        });
        const pres = document.querySelectorAll("pre.mermaid:not([data-mermaid-rendered])");
        if (pres.length > 0) {
          for (const el of pres) {
            el.setAttribute("data-mermaid-rendered", "1");
          }
          await mermaid.run({ nodes: Array.from(pres) });
        }
      </script>
    )}
  </body>
</html>

<style>
  .nav__lang {
    border: 1px solid var(--border);
    padding: 6px 12px;
    border-radius: 999px;
    color: var(--text) !important;
    font-size: 13px;
    font-weight: 600;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .nav__lang:hover {
    border-color: var(--accent);
    background: rgba(124, 156, 255, 0.08);
  }
</style>
