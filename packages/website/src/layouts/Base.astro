---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Rotom · 数字员工 Mesh",
  description = "一个中心化的 Agent 协作网络。Master 中转 + Executor 抢单 + rotom CLI 调用,把 claude / codex / hermes / openclaw 等专业 CLI 工具封装成可协作的数字员工。",
} = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/rotom.jpeg" />
    <meta property="og:type" content="website" />
    <title>{title}</title>
  </head>
  <body>
    <nav class="nav">
      <div class="wrap nav__inner">
        <a href="/" class="brand">
          <img src="/rotom.jpeg" alt="Rotom" class="brand__logo" />
          <span class="brand__name">Rotom</span>
          <span class="brand__tag">A2A Workspace</span>
        </a>
        <div class="nav__links">
          <a href="#features">特性</a>
          <a href="#group-play">群指导</a>
          <a href="#proactive">主动出击</a>
          <a href="#architecture">架构</a>
          <a href="#screenshots">截图</a>
          <a href="#quickstart">快速开始</a>
          <a href="#docs">文档</a>
          <a href="https://code.alipay.com/cattery/rotom" class="nav__cta">GitHub</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
