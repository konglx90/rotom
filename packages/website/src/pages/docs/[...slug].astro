---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs.map((d) => ({
    // id 可能是 "FEDERATION" 或 "claude-tag/claude-tag-introduction"
    // URL 用 id 整段,需要 [...slug] rest 参数
    params: { slug: d.id },
    props: { doc: d },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);

// 简单 title 兜底:文档没有 frontmatter title 时,从 id 派生
const title = doc.data.title || doc.id.replace(/-/g, " ").replace(/\//g, " · ");
const description = doc.data.description;

// 该文档是否含 mermaid 代码块 —— 启用客户端渲染
const hasMermaid = /```mermaid/.test(doc.body || "");
---
<Base title={`${title} · Rotom 文档`} description={description} withMermaid={hasMermaid}>
  <article class="doc-page">
    <div class="wrap doc-page__inner">
      <a href="/docs/" class="doc-back">← 文档索引</a>
      <header class="doc-page__head">
        <span class="eyebrow">DOCS · {doc.id}.md</span>
        <h1>{title}</h1>
        {description && <p class="lead">{description}</p>}
      </header>

      <div class="prose">
        <Content />
      </div>

      <footer class="doc-page__foot">
        <a href="/docs/">← 返回文档索引</a>
        <a href={`https://code.alipay.com/cattery/rotom/blob/master/docs/${doc.id}.md`} target="_blank" rel="noreferrer">
          在仓库查看原始 Markdown →
        </a>
      </footer>
    </div>
  </article>
</Base>

<style>
  .doc-page {
    padding: 48px 0 80px;
  }
  .doc-page__inner {
    max-width: 880px;
  }
  .doc-back {
    display: inline-block;
    margin-bottom: 24px;
    color: var(--text-mute);
    font-size: 13.5px;
  }
  .doc-page__head {
    margin-bottom: 32px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 24px;
  }
  .doc-page__head h1 {
    font-size: 36px;
    margin: 8px 0 12px;
    letter-spacing: -0.015em;
  }
  .doc-page__foot {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 13.5px;
  }
  .prose {
    color: var(--text);
    font-size: 15.5px;
    line-height: 1.75;
  }
  .prose :global(h1) { font-size: 28px; margin: 32px 0 16px; letter-spacing: -0.01em; }
  .prose :global(h2) { font-size: 22px; margin: 32px 0 14px; letter-spacing: -0.01em; }
  .prose :global(h3) { font-size: 18px; margin: 26px 0 12px; }
  .prose :global(h4) { font-size: 16px; margin: 22px 0 10px; color: var(--text-dim); }
  .prose :global(p)  { margin: 14px 0; }
  .prose :global(a)   { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(a:hover) { color: var(--accent-2); }
  .prose :global(strong)  { color: var(--text); font-weight: 600; }
  .prose :global(em)      { color: var(--accent-2); font-style: normal; }
  .prose :global(code)   {
    background: var(--bg-elev2);
    padding: 2px 6px;
    border-radius: 6px;
    font-size: 0.88em;
    color: var(--accent-2);
    font-family: "JetBrains Mono", "SF Mono", Menlo, Consolas, monospace;
  }
  .prose :global(pre) {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    overflow-x: auto;
    margin: 18px 0;
    font-size: 13.5px;
    line-height: 1.6;
  }
  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    color: var(--text);
    font-size: inherit;
  }
  .prose :global(pre.mermaid) {
    background: var(--bg-elev);
    text-align: center;
  }
  .prose :global(pre.mermaid svg) { max-width: 100%; height: auto; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 4px 16px;
    margin: 16px 0;
    color: var(--text-dim);
    background: rgba(124, 156, 255, 0.04);
    border-radius: 0 6px 6px 0;
  }
  .prose :global(blockquote p) { margin: 6px 0; }
  .prose :global(ul),
  .prose :global(ol) { padding-left: 22px; margin: 14px 0; }
  .prose :global(li) { margin: 4px 0; }
  .prose :global(ul) > li::marker { color: var(--accent); }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 18px 0;
    font-size: 14px;
    display: block;
    overflow-x: auto;
  }
  .prose :global(th),
  .prose :global(td) {
    text-align: left;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .prose :global(th) {
    background: var(--bg-elev2);
    color: var(--text-dim);
    font-weight: 600;
    font-size: 13px;
  }
  .prose :global(tr:last-child td) { border-bottom: none; }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 32px 0;
  }
  .prose :global(img) {
    max-width: 100%;
    border-radius: 8px;
    border: 1px solid var(--border);
    margin: 16px 0;
  }
</style>
