---
import Base from "../../layouts/Base.astro";
import DocSidebar from "../../components/DocSidebar.astro";
import { buildDocTree } from "../../utils/docs";

const tree = await buildDocTree("zh");
---
<Base title="文档 · Rotom">
  <div class="doc-layout">
    <DocSidebar tree={tree} lang="zh" />
    <main class="doc-content">
      <div class="doc-home">
        <span class="eyebrow">DOCS INDEX</span>
        <h1>文档中心</h1>
        <p class="lead">
          所有文档随仓库一同发布，内容位于 <code>packages/website/docs/</code>。
          从左侧目录选择文档阅读，支持 mermaid 图表 / 表格 / 代码块。
        </p>
        <div class="doc-home__tips">
          <h3>快速入口</h3>
          <ul>
            <li><a href="/docs/user/get_started/">快速开始</a> — 全局安装 + 一键启动</li>
            <li><a href="/docs/user/user_guide/">协作指南</a> — 群聊 / Issue / Ask 全流程</li>
            <li><a href="/docs/federation/federation/">Federation</a> — OPC + 联邦团队</li>
            <li><a href="/docs/dev/dev_delivery_workflow/">研发交付工作流</a> — Issue 全生命周期 SOP</li>
          </ul>
        </div>
        <p style="margin-top:32px;color:var(--text-mute);font-size:13px;">
          ※ <code>claude-tag/</code> 和 <code>infos/</code> 为内部设计稿，未在索引中展示。
        </p>
      </div>
    </main>
  </div>
</Base>
<style>
  .doc-layout { display: flex; min-height: calc(100vh - 56px); }
  .doc-content { flex: 1; max-width: 880px; padding: 48px 48px 80px; }
  .doc-home h1 { font-size: 36px; margin: 8px 0 12px; letter-spacing: -0.015em; font-weight: 900; line-height: 0.85; font-feature-settings: "calt" 1; }
  .doc-home__tips { margin-top: 40px; padding: 24px; background: var(--bg-elev); border-radius: var(--radius-sm); border: 1px solid var(--border); }
  .doc-home__tips h3 { margin: 0 0 12px; font-size: 16px; font-weight: 600; }
  .doc-home__tips ul { margin: 0; padding: 0; list-style: none; }
  .doc-home__tips li { margin: 6px 0; font-size: 14px; }
  .doc-home__tips a { color: #2a7a4e; text-decoration: underline; text-underline-offset: 2px; }
  .doc-home__tips a:hover { color: var(--text); }
  @media (max-width: 768px) { .doc-layout { flex-direction: column; } .doc-content { padding: 24px 20px 60px; } }
</style>