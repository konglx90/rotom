---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Footer from "../../components/Footer.astro";

// 内部文档 / 临时记录 → 不在官网 docs 索引里展示
// 支持顶级 id(REFACTOR_BACKLOG)和子目录前缀(claude-tag/)
const HIDDEN = [
  /^REFACTOR_BACKLOG$/,        // 内部 backlog
  /^review$/,                  // 内部 review
  /^toolbox-tab-reorder$/,     // 内部 UI 调整记录
  /^codex-sandbox-network-blocked$/,  // 故障速记
  /^minimax-connection-error$/,        // 故障速记
  /^claude-tag\//,             // claude-tag 子目录:设计讨论稿,索引里不展示
  /^infos\//,                  // infos 子目录:早期 features 设计稿
];
const isHidden = (id: string) => HIDDEN.some((re) => re.test(id));

const all = await getCollection("docs");
const docs = all
  .filter((d) => !isHidden(d.id))
  .sort((a, b) => a.id.localeCompare(b.id));

// 给没有 H1 的文档一个默认标题(去掉 .md)
function titleOf(id: string): string {
  return id.replace(/\//g, " · ").replace(/-/g, " ");
}

const groups = [
  { match: /INSTALL|README|FEDERATION|QUICK_REF/, title: "上手 / 配置" },
  { match: /AGENT_USER_GUIDE|AGENT_WHITEBOX|ASK_BRIDGE|AGENT_ASK_REPLY/, title: "Agent 协作" },
  { match: /GROUP_CHAT|DEV_DELIVERY/, title: "群聊 / 工作流" },
];
const grouped = groups.map((g) => ({
  ...g,
  items: docs.filter((d) => g.match.test(d.id)),
}));
const leftover = docs.filter((d) => !groups.some((g) => g.match.test(d.id)));
---
<Base title="文档 · Rotom">
  <section class="section section--first" style="padding-top:48px;">
    <div class="wrap">
      <span class="eyebrow">DOCS INDEX</span>
      <h1>文档中心</h1>
      <p class="lead">
        所有文档随仓库一同发布,内容来自仓库根 <code>/docs/*.md</code>。点击文档名进入在线渲染页(支持 mermaid / 表格 / 代码块)。
      </p>

      {grouped.map((g) => g.items.length > 0 && (
        <div class="doc-group">
          <h2 class="subhead">{g.title}</h2>
          <div class="docs">
            {g.items.map((d) => (
              <a class="doc" href={`/docs/${d.id}/`}>
                <h4>{d.data.title || titleOf(d.id)}</h4>
                <p>{d.data.description || `docs/${d.id}.md`}</p>
                <span class="doc__ext">查看文档 →</span>
              </a>
            ))}
          </div>
        </div>
      ))}

      {leftover.length > 0 && (
        <div class="doc-group">
          <h2 class="subhead">其他</h2>
          <div class="docs">
            {leftover.map((d) => (
              <a class="doc" href={`/docs/${d.id}/`}>
                <h4>{d.data.title || titleOf(d.id)}</h4>
                <p>{d.data.description || `docs/${d.id}.md`}</p>
                <span class="doc__ext">查看文档 →</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <p style="margin-top:32px;color:var(--text-mute);font-size:13px;">
        ※ 部分内部文档(REFACTOR_BACKLOG / review / 故障速记等)未在官网索引,但仍可在仓库 <code>/docs/</code> 直接查看。
      </p>
    </div>
  </section>
</Base>

<style>
  .doc-group { margin-bottom: 32px; }
</style>
