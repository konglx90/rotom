---
import { getCollection, render } from "astro:content";
import Base from "../../../layouts/Base.astro";
import DocSidebar from "../../../components/DocSidebar.astro";
import { buildDocTree } from "../../../utils/docs";

export async function getStaticPaths() {
  const docs = await getCollection("docsEn");
  return docs.map((d) => ({
    params: { slug: d.id },
    props: { doc: d },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const tree = await buildDocTree("en");

const title = doc.data.title || doc.id.replace(/-/g, " ").replace(/\//g, " · ");
const description = doc.data.description;
const hasMermaid = /```mermaid/.test(doc.body || "");
---
<Base lang="en" title={`${title} · Rotom Docs`} description={description} withMermaid={hasMermaid}>
  <div class="doc-layout">
    <DocSidebar tree={tree} currentPath={doc.id} lang="en" />
    <main class="doc-content">
      <article class="doc-page">
        <div class="wrap doc-page__inner">
          <header class="doc-page__head">
            <span class="eyebrow">DOCS</span>
            <h1>{title}</h1>
            {description && <p class="lead">{description}</p>}
          </header>
          <div class="prose">
            <Content />
          </div>
          <footer class="doc-page__foot">
            <a href={`https://code.alipay.com/cattery/rotom/blob/master/packages/website/docs/en/${doc.id}.md`} target="_blank" rel="noreferrer">
              View raw Markdown in repo →
            </a>
          </footer>
        </div>
      </article>
    </main>
  </div>
</Base>

<style>
  .doc-layout { display: flex; min-height: calc(100vh - 56px); }
  .doc-content { flex: 1; max-width: 880px; padding: 40px 48px 80px; }
  .doc-page { padding: 0; }
  .doc-page__inner { max-width: 720px; }
  .doc-page__head { margin-bottom: 32px; border-bottom: 1px solid var(--border); padding-bottom: 24px; }
  .doc-page__head h1 { font-size: 36px; margin: 8px 0 12px; letter-spacing: -0.015em; font-weight: 900; line-height: 0.85; font-feature-settings: "calt" 1; }
  .doc-page__foot { margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--border); font-size: 13.5px; }
  .prose { color: var(--text); font-size: 15.5px; line-height: 1.75; font-feature-settings: "calt" 1; }
  .prose :global(h1) { font-size: 28px; margin: 32px 0 16px; letter-spacing: -0.01em; font-weight: 900; line-height: 0.85; }
  .prose :global(h2) { font-size: 22px; margin: 32px 0 14px; letter-spacing: -0.01em; font-weight: 700; line-height: 1.1; border-bottom: 2px solid var(--accent); padding-bottom: 6px; display: inline-block; }
  .prose :global(h3) { font-size: 18px; margin: 26px 0 12px; font-weight: 600; }
  .prose :global(h4) { font-size: 16px; margin: 22px 0 10px; color: var(--text-dim); font-weight: 600; }
  .prose :global(p)  { margin: 14px 0; }
  .prose :global(a)   { color: #2a7a4e; text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(a:hover) { color: var(--text); }
  .prose :global(strong)  { color: var(--text); font-weight: 600; }
  .prose :global(em)      { color: var(--accent-2); font-style: normal; }
  .prose :global(code)   { background: var(--code-bg); padding: 2px 6px; border-radius: 6px; font-size: 0.88em; color: var(--accent-2); font-family: "JetBrains Mono","SF Mono",Menlo,Consolas,monospace; border: 1px solid rgba(14,15,12,0.15); }
  .prose :global(pre) { background: var(--code-bg); border: 1px solid rgba(14,15,12,0.15); border-radius: 10px; padding: 14px 16px; overflow-x: auto; margin: 18px 0; font-size: 13.5px; line-height: 1.6; }
  .prose :global(pre code) { background: transparent; padding: 0; color: var(--text); font-size: inherit; border: none; }
  .prose :global(pre.mermaid) { background: var(--bg-elev); text-align: center; }
.prose :global(pre.astro-code){background:var(--code-bg)!important;border:1px solid rgba(14,15,12,0.15)!important;border-radius:10px;padding:14px 16px!important}
  .prose :global(pre.mermaid svg) { max-width: 100%; height: auto; }
  .prose :global(blockquote) { border-left: 3px solid var(--accent); padding: 4px 16px; margin: 16px 0; color: var(--text-dim); background: rgba(159, 232, 112, 0.06); border-radius: 0 6px 6px 0; }
  .prose :global(blockquote p) { margin: 6px 0; }
  .prose :global(ul), .prose :global(ol) { padding-left: 22px; margin: 14px 0; }
  .prose :global(li) { margin: 4px 0; }
  .prose :global(ul) > li::marker { color: var(--accent); }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 18px 0; font-size: 14px; display: block; overflow-x: auto; }
  .prose :global(th), .prose :global(td) { text-align: left; padding: 10px 14px; border-bottom: 1px solid rgba(14,15,12,0.08); vertical-align: top; }
  .prose :global(th) { background: var(--bg-elev2); color: var(--text-dim); font-weight: 600; font-size: 13px; }
  .prose :global(tr:last-child td) { border-bottom: none; }
  .prose :global(hr) { border: none; border-top: 1px solid var(--border); margin: 32px 0; }
  .prose :global(img) { max-width: 100%; border-radius: 8px; border: 1px solid rgba(14,15,12,0.15); margin: 16px 0; }
  @media (max-width: 768px) {
    .doc-layout { flex-direction: column; }
    .sidebar { width: 100%; position: static; height: auto; border-right: none; border-bottom: 1px solid var(--border); }
    .doc-content { padding: 24px 20px 60px; }
  }
</style>