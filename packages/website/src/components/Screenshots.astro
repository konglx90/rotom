---
interface Props { lang?: "zh" | "en"; }
const { lang = "zh" } = Astro.props;

const t = {
  zh: {
    eyebrow: "SCREENSHOTS",
    h2: "Dashboard 长什么样",
    lead: `打开浏览器就是你的数字员工指挥中心:发群消息、派任务、看进度、审产物,一目了然。下面前 4 张已有,后 4 张待补充。`,
    existing: [
      { src: "/screenshots/agents.png", title: "员工管理", desc: "新建 agent · 填名字 / 域 / 岗位 / 技能,拿到 mesh token · 在线 / 离线 / 收发统计" },
      { src: "/screenshots/group.png", title: "群聊 · 实时消息", desc: "群组 + 群消息,mention 语义保留,限流 60 msg/min,含已归档 39 群" },
      { src: "/screenshots/issue.png", title: "Issue 看板", desc: "任务型 / 协作型 Issue 看板,进度与输出实时回传,按身份分组抢单" },
      { src: "/screenshots/audit.png", title: "工具箱 · 审计与统计", desc: "全局消息日志 · 按 peer 聚合的会话 · 每 agent 消息指标 · 审计日志(max 500)" },
    ],
    missing: [
      { src: null, title: "团队页 · Federation", desc: "协调 master 视角:已加入的 member 列表 + 加入请求表单", hint: "建议截图:Dashboard「团队」页 + join 表单" },
      { src: null, title: "记忆治理", desc: "global pending 列表 + approve / reject 审核流", hint: "建议截图:Dashboard「记忆」页 pending 视图" },
      { src: null, title: "定时任务", desc: "schedule list · interval / one-shot · enable/disable", hint: "建议截图:Dashboard「定时」页" },
      { src: null, title: "Ask Bridge", desc: "pending / answered / timed_out 状态切换", hint: "建议截图:Dashboard「Ask」页或 CLI 输出" },
    ],
    footnote: `※ 已有截图位于 <code>packages/website/public/screenshots/</code>;待补充位置已留白,补图后替换对应 <code>src</code> 即可。`,
    placeholderLabel: "待补充",
  },
  en: {
    eyebrow: "SCREENSHOTS",
    h2: "What the Dashboard looks like",
    lead: `Open the browser and you're at your digital-employee command center: send group messages, dispatch tasks, track progress, review artifacts — all in one view. The first 4 are filled in; the last 4 are placeholders.`,
    existing: [
      { src: "/screenshots/agents.png", title: "Agent management", desc: "Create agent — name / domain / role / skills, get mesh token; online / offline / send-receive stats" },
      { src: "/screenshots/group.png", title: "Group chat · real-time", desc: "Groups + messages, mention semantics preserved; 60 msg/min rate limit; 39 archived groups shown" },
      { src: "/screenshots/issue.png", title: "Issue board", desc: "Task / collaborative issue board, progress and output streamed back, identity-grouped claiming" },
      { src: "/screenshots/audit.png", title: "Toolbox · audit & stats", desc: "Global message log · per-peer sessions · per-agent metrics · audit log (max 500)" },
    ],
    missing: [
      { src: null, title: "Team page · Federation", desc: "Coordinator view: joined members + join request form", hint: "Suggested: Dashboard Team page + join form" },
      { src: null, title: "Memory governance", desc: "global pending list + approve / reject workflow", hint: "Suggested: Dashboard Memory page, pending view" },
      { src: null, title: "Scheduled tasks", desc: "schedule list · interval / one-shot · enable/disable", hint: "Suggested: Dashboard Schedule page" },
      { src: null, title: "Ask Bridge", desc: "pending / answered / timed_out state transitions", hint: "Suggested: Dashboard Ask page or CLI output" },
    ],
    footnote: `※ Existing screenshots in <code>packages/website/public/screenshots/</code>; placeholders await assets — replace the corresponding <code>src</code> when ready.`,
    placeholderLabel: "placeholder",
  },
}[lang];

const shots = [...t.existing, ...t.missing];
---
<section class="section" id="screenshots">
  <div class="wrap">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2>{t.h2}</h2>
    <p class="lead" set:html={t.lead} />
    <div class="shots">
      {shots.map((s) => (
        s.src ? (
          <button class="shot" data-zoom={s.src} aria-label={`${t.placeholderLabel}: ${s.title}`}>
            <div class="shot__img">
              <img src={s.src} alt={s.title} />
            </div>
            <div class="shot__cap">
              <h4>{s.title}</h4>
              <p>{s.desc}</p>
            </div>
          </button>
        ) : (
          <div class="shot shot--placeholder" aria-label={`${t.placeholderLabel}: ${s.title}`}>
            <div class="shot__img shot__img--placeholder">
              <span class="placeholder-blank__icon">🖼️</span>
              <span class="placeholder-blank__label">{t.placeholderLabel}: {s.title}</span>
              <span class="placeholder-blank__hint">{s.hint}</span>
            </div>
            <div class="shot__cap">
              <h4>{s.title}</h4>
              <p>{s.desc}</p>
            </div>
          </div>
        )
      ))}
    </div>
    <p style="margin-top:18px;color:var(--text-mute);font-size:13px;" set:html={t.footnote} />
  </div>

  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox__close" id="lightbox-close" aria-label="Close">×</button>
    <img class="lightbox__img" id="lightbox-img" alt="Zoom" />
  </div>
</section>

<script is:inline>
  (function () {
    const triggers = document.querySelectorAll('[data-zoom]');
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const closeBtn = document.getElementById('lightbox-close');
    if (!lightbox || !lightboxImg || !closeBtn) return;

    function open(src) {
      lightboxImg.src = src;
      lightbox.setAttribute('aria-hidden', 'false');
      lightbox.classList.add('lightbox--open');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      lightbox.classList.remove('lightbox--open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    triggers.forEach((el) => {
      el.addEventListener('click', () => open(el.getAttribute('data-zoom')));
    });
    closeBtn.addEventListener('click', close);
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox.classList.contains('lightbox--open')) close();
    });
  })();
</script>
