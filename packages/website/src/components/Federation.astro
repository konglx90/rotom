---
interface Props { lang?: "zh" | "en"; }
const { lang = "zh" } = Astro.props;

const t = {
  zh: {
    eyebrow: "FEDERATION · 联邦玩法",
    h2: "OPC 默认 + Federation 叠加",
    lead: `Rotom 的设计哲学:<strong>每台机器先自治,再联邦</strong>。默认形态是个人 OPC(开箱即用、免 token),需要跨机协作时再 runtime 加入团队,无需重启、无需迁移数据。`,
    modes: [
      {
        icon: "🚀", title: "OPC · 个人数字员工", tag: "默认形态 · 每台机器",
        desc: "一命令拉起 master + executor,自动建默认 agent + 默认 group,本机走 loopback 信任,免 mesh_token,断网可用。",
        bullet: [
          "masterId 持久稳定:8 字符 base36,换网络/改 IP 不影响身份",
          "hostname 校验:拒绝 IP 字面量(移动电脑 IP 不稳定)",
          "scanClis 自动注册:claude / codex / hermes / openclaw / pi 各起一个 agent",
          "ROTOM_FEDERATION_DISABLED=1 可强制纯 standalone",
        ],
      },
      {
        icon: "🌐", title: "Federation · 团队联邦", tag: "可选叠加 · 星型拓扑",
        desc: "协调 master(ROTOM_MASTER_ROLE=coordination)中转跨机消息,member master 主动 outbound 连接,数据归属本地,协调只持有路由元信息。",
        bullet: [
          "runtime join/leave:Dashboard「团队」页填地址即可加入,无需重启",
          "移动电脑友好:member 是 outbound 主动连接,切网自动重连",
          "跨机可见性:本机 agent 自动 publish 到协调 master,其他 member 可见",
          "数据归属本地:agent / memory / issue 始终留在本地 master",
        ],
      },
    ],
    topologyHead: "星型拓扑",
    topologyPlaceholder: "待补充 Federation 星型拓扑图",
    topologyHint: `建议画:中心 Coordination Master,周围 3-4 个 Member Master 用 outbound 箭头连入;\n每个 Member 下挂 1-2 个 Agent 节点;协调上方标 "路由元信息",Member 方框标 "数据归属本地"`,
    rolesHead: "三种 Master 角色",
    roleCols: ["角色", "说明", "环境变量"],
    roles: [
      { name: "standalone", desc: "默认 · 单机 OPC,无协调,数据完全本地", env: "(无需)" },
      { name: "coordination", desc: "协调 master · 接收 member 连入、转发跨机消息", env: "ROTOM_MASTER_ROLE=coordination" },
      { name: "member", desc: "成员 master · 主动连协调,本机数据保留,跨机可见性上推", env: "ROTOM_MASTER_ROLE=member" },
    ],
    cmdHead: "一命令启动",
    coordCode: `rotom run federation
# 等价 ROTOM_MASTER_ROLE=coordination pnpm start
# 默认端口 28800,Dashboard → 团队页可看 join 请求`,
    coordHead: "协调 master(稳定地址机器)",
    memberHead: "member master(移动电脑也行)",
    memberCode: `# 方式 A:Dashboard「团队」页填地址加入(runtime 切换)
# 方式 B:写 ~/.rotom/team.json
{
  "id": "「协调 masterId,8 字符 base36」",
  "name": "阿甘团队",
  "coord_endpoints": ["ws://coord-host:28800"]
}

ROTOM_MASTER_ROLE=member pnpm start`,
    footnote: `※ 完整 Federation 协议见 <code>docs/FEDERATION.md</code>(新建中);REST 端点见 README 的 <em>Identity / Teams</em> 段。`,
  },
  en: {
    eyebrow: "FEDERATION · TEAM FED",
    h2: "OPC default + Federation overlay",
    lead: `Rotom's philosophy: <strong>every machine self-governs first, then federates</strong>. The default form is personal OPC (out-of-the-box, no token). When you need cross-machine collaboration, join a team at runtime — no restart, no data migration.`,
    modes: [
      {
        icon: "🚀", title: "OPC · Personal Digital Employee", tag: "Default form · per machine",
        desc: "One command brings up master + executor, creates a default agent + group, uses loopback trust, no mesh_token required, works offline.",
        bullet: [
          "Persistent masterId: 8-char base36, survives network/IP changes",
          "Hostname validation: rejects IP literals (mobile IPs are unstable)",
          "scanClis auto-registration: claude / codex / hermes / openclaw / pi each get an agent",
          "ROTOM_FEDERATION_DISABLED=1 forces pure standalone",
        ],
      },
      {
        icon: "🌐", title: "Federation · Team Federation", tag: "Optional overlay · star topology",
        desc: "Coordination master (ROTOM_MASTER_ROLE=coordination) relays cross-machine messages. Member masters connect outbound. Data stays local; coordinator only holds routing metadata.",
        bullet: [
          "Runtime join/leave: Dashboard → Team page → enter coordinator address, no restart",
          "Mobile-friendly: members connect outbound, auto-reconnect on network change",
          "Cross-machine visibility: local agents auto-publish to coordinator, visible to other members",
          "Data stays local: agent / memory / issue always on the local master",
        ],
      },
    ],
    topologyHead: "Star topology",
    topologyPlaceholder: "Federation star topology — placeholder",
    topologyHint: `Suggested: central Coordination Master, with 3-4 Member Masters connecting outbound;\neach Member holds 1-2 Agent nodes; coordinator labeled "routing metadata", Members labeled "data local"`,
    rolesHead: "Three Master Roles",
    roleCols: ["Role", "Description", "Env var"],
    roles: [
      { name: "standalone", desc: "Default · single-machine OPC, no coordinator, fully local", env: "(none)" },
      { name: "coordination", desc: "Coordinator master · accepts member connections, relays cross-machine messages", env: "ROTOM_MASTER_ROLE=coordination" },
      { name: "member", desc: "Member master · connects to coordinator outbound, local data preserved, cross-machine visibility published", env: "ROTOM_MASTER_ROLE=member" },
    ],
    cmdHead: "One-command startup",
    coordCode: `rotom run federation
# equivalent: ROTOM_MASTER_ROLE=coordination pnpm start
# Default port 28800, Dashboard → Team page shows join requests`,
    coordHead: "Coordinator master (stable-address machine)",
    memberHead: "Member master (mobile-friendly)",
    memberCode: `# Option A: Dashboard → Team page → enter address (runtime switch)
# Option B: write ~/.rotom/team.json
{
  "id": "「coordinator masterId, 8-char base36」",
  "name": "Agan Team",
  "coord_endpoints": ["ws://coord-host:28800"]
}

ROTOM_MASTER_ROLE=member pnpm start`,
    footnote: `※ Full Federation protocol in <code>docs/FEDERATION.md</code>; REST endpoints in README's <em>Identity / Teams</em> section.`,
  },
}[lang];
---
<section class="section" id="federation">
  <div class="wrap">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2>{t.h2}</h2>
    <p class="lead" set:html={t.lead} />

    <div class="grid2">
      {t.modes.map((m) => (
        <div class="card">
          <div class="card__icon">{m.icon}</div>
          <h3>{m.title}</h3>
          <p>{m.desc}</p>
          <div style="margin-top:12px;font-size:12px;color:var(--accent-2);letter-spacing:.06em;">{m.tag}</div>
          <ul style="margin-top:10px;">
            {m.bullet.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <h3 class="subhead">{t.topologyHead}</h3>
    <div class="arch arch--placeholder" aria-label={t.topologyPlaceholder}>
      <div class="placeholder-blank placeholder-blank--wide">
        <span class="placeholder-blank__icon">🌐</span>
        <span class="placeholder-blank__label">{t.topologyPlaceholder}</span>
        <span class="placeholder-blank__hint" style="white-space:pre-wrap">{t.topologyHint}</span>
      </div>
    </div>

    <h3 class="subhead">{t.rolesHead}</h3>
    <div class="role-list">
      <div class="role-row role-row--head">
        <div class="role-row__name">{t.roleCols[0]}</div>
        <div class="role-row__desc">{t.roleCols[1]}</div>
        <div class="role-row__env">{t.roleCols[2]}</div>
      </div>
      {t.roles.map((r) => (
        <div class="role-row">
          <div class="role-row__name"><code>{r.name}</code></div>
          <div class="role-row__desc">{r.desc}</div>
          <div class="role-row__env"><code>{r.env}</code></div>
        </div>
      ))}
    </div>

    <h3 class="subhead">{t.cmdHead}</h3>
    <div class="grid2">
      <div class="codeblock">
        <div class="codeblock__head">{t.coordHead}</div>
        <pre><code>{t.coordCode}</code></pre>
      </div>
      <div class="codeblock">
        <div class="codeblock__head">{t.memberHead}</div>
        <pre><code>{t.memberCode}</code></pre>
      </div>
    </div>

    <p style="margin-top:24px;color:var(--text-mute);font-size:13px;" set:html={t.footnote} />
  </div>
</section>
