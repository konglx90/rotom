---
interface Props { lang?: "zh" | "en"; }
const { lang = "zh" } = Astro.props;

const t = {
  zh: {
    eyebrow: "CLI REFERENCE · 命令速查",
    h2: "rotom CLI 一图流",
    lead: `<code>rotom [--as &lt;agent&gt;] [--pretty] &lt;command&gt; [args]</code>。Agent 选择优先级:<code>ROTOM_AGENT</code> &gt; <code>--as</code> &gt; <code>~/.rotom/config.json#defaultAgent</code>;都没解析到则拒跑(防止误用他人 token)。`,
    groups: [
      { icon: "🚀", title: "Process · 进程控制", desc: "Master / Executor / 一站式启动,无需 agent 身份",
        cmds: [
          ["run opc", "启动 master + 自动 spawn executor(OPC 默认)"],
          ["run federation", "启动协调 master(注入 ROTOM_MASTER_ROLE=coordination)"],
          ["master <start|stop|restart|status>", "Master 生命周期(支持 colon 别名 master:start)"],
          ["executor [--config <path>]", "起 executor workers,默认读 ~/.rotom/executor.config.json"],
          ["status", "Master health check(无需 agent)"],
        ] },
      { icon: "🧩", title: "Bootstrap · 首次接入", desc: "一台机器一个 CLI 一个 agent",
        cmds: [
          ["init", "探测 claude/codex/hermes,问名字+master IP,写 executor.config.json"],
          ["join <host:port> --name <n> --domain <d> --cli-tool <t>", "首次申请 token 落盘(本地交互式 CLI 用)"],
        ] },
      { icon: "👤", title: "Identity · 身份与配置", desc: "多身份切换 + 配置管理",
        cmds: [
          ["whoami", "当前解析到的 agent"],
          ["config show | init | use <name>", "查看 / 初始化 / 设默认 agent"],
          ["config add-executor <name> <json>", "注册 executor worker"],
          ["config remove <name>", "移除 agent 配置"],
        ] },
      { icon: "💬", title: "Group · 群聊", desc: "建群 / 拉人 / 发消息 / 历史",
        cmds: [
          ["group create <title> --agents a,b [--a2a-direct]", "一键建群+拉人,默认加载群指导模板"],
          ["group list | members <id> | history <id>", "群列表 / 成员 / 历史"],
          ["group new-messages <id> --since <ISO>", "轮询:某时间点之后的新消息"],
          ["group send <id> <target> <msg...> [--need-reply]", "发消息;--need-reply 一问一答"],
          ["group archive <id> | unarchive <id>", "归档 / 取消归档"],
        ] },
      { icon: "📋", title: "Issue · 任务派发", desc: "任务型 / 协作型 Issue,创建即派发",
        cmds: [
          ["issue create <groupId> --description D [--title T] [--priority P] [--assignee A] [--run]", "创建并可选立即派发(--run 必须 --assignee)"],
          ["issue update <id> [--title T] [--description D] [--status S] [--assignee A|--unassign]", "局部更新字段"],
          ["issue cancel <id> | delete <id>", "取消 / 删除"],
          ["issue list <groupId> [--status S] [--type task]", "群内 Issue 列表"],
          ["issue show <id> | events <id> | messages <id>", "详情 / 时间线 / 关联消息"],
          ["issue comment <id> --message M [--reply-to <eventId>]", "评论(可回复特定事件)"],
        ] },
      { icon: "🧠", title: "Memory · 记忆治理", desc: "note=纯人看 / memory=agent 可见,global 走审核",
        cmds: [
          ["memory add <groupId> --key K --value V --category C [--scope global] [--visibility V]", "新增记忆"],
          ["memory search <kw> <groupId> [--scope g|global] [--category C]", "关键词检索"],
          ["memory list <groupId> [--scope global] [--type note|memory|all] [--tags t1,t2]", "列表(可过滤)"],
          ["memory promote <id> --visibility global", "提升到 global(进 pendingReview)"],
          ["memory pending <groupId> [--scope global] | approve <id> | reject <id>", "审核流"],
          ["memory stats <groupId> [--scope global]", "记忆统计"],
        ] },
      { icon: "🎯", title: "Skill / Schedule / Ask", desc: "技能派活 + 群内定时 + 一问一答",
        cmds: [
          ["skill list <groupId> | bind <groupId> --skill S --agent A | unbind ...", "技能绑定管理"],
          ["schedule add --group <id> --mode agent|message --prompt P (--every D|--in D|--at ISO)", "建定时任务"],
          ["schedule update <id> | enable <id> | disable <id> | trigger <id> | remove <id>", "调度控制"],
          ["ask <groupId> <target> <question...> [--timeout 5m] [--escalate-to <真人>]", "提问 + 自动建 bridge"],
          ["ask list --group <id> [--status S] | show <id> | cancel <id>", "Ask 查询 / 取消"],
        ] },
      { icon: "📦", title: "Repo · Worktree 缓存", desc: "本机 FS 操作,不需要 agent",
        cmds: [
          ["repo list", "列出 ~/.rotom/repos/ 下所有 bare clone + worktree 数 + 磁盘占用"],
          ["repo prune [--remove-orphans]", "清理孤儿 worktree 元数据,可选删除无引用 30 天未 fetch 的 bare clone"],
          ["repo fetch <repo-id> | remove <repo-id>", "显式 fetch / 删除 bare clone"],
        ] },
    ],
    footnote: `※ 完整命令文档见 <code>src/cli/rotom.ts</code> 顶部 HELP;运行 <code>rotom help</code> 可直接查看。`,
  },
  en: {
    eyebrow: "CLI REFERENCE · CHEAT SHEET",
    h2: "rotom CLI at a glance",
    lead: `<code>rotom [--as &lt;agent&gt;] [--pretty] &lt;command&gt; [args]</code>. Agent resolution priority: <code>ROTOM_AGENT</code> &gt; <code>--as</code> &gt; <code>~/.rotom/config.json#defaultAgent</code>; if none resolves, rotom refuses to run (prevents accidentally using another agent's token).`,
    groups: [
      { icon: "🚀", title: "Process · lifecycle", desc: "Master / Executor / one-shot startup; no agent identity needed",
        cmds: [
          ["run opc", "start master + auto-spawn executor (OPC default)"],
          ["run federation", "start coordinator master (injects ROTOM_MASTER_ROLE=coordination)"],
          ["master <start|stop|restart|status>", "Master lifecycle (also colon alias master:start)"],
          ["executor [--config <path>]", "start executor workers; reads ~/.rotom/executor.config.json by default"],
          ["status", "Master health check (no agent needed)"],
        ] },
      { icon: "🧩", title: "Bootstrap · first-time onboarding", desc: "one machine, one CLI, one agent",
        cmds: [
          ["init", "detect claude/codex/hermes, ask for name + master IP, write executor.config.json"],
          ["join <host:port> --name <n> --domain <d> --cli-tool <t>", "first-time token grant + save (local interactive CLI)"],
        ] },
      { icon: "👤", title: "Identity · identity & config", desc: "multi-identity switching + config",
        cmds: [
          ["whoami", "currently-resolved agent"],
          ["config show | init | use <name>", "show / init / set default agent"],
          ["config add-executor <name> <json>", "register an executor worker"],
          ["config remove <name>", "remove agent config"],
        ] },
      { icon: "💬", title: "Group · chat", desc: "create / invite / send / history",
        cmds: [
          ["group create <title> --agents a,b [--a2a-direct]", "create group + invite; loads group guidance template by default"],
          ["group list | members <id> | history <id>", "list / members / history"],
          ["group new-messages <id> --since <ISO>", "poll: new messages after timestamp"],
          ["group send <id> <target> <msg...> [--need-reply]", "send message; --need-reply = one Q one A"],
          ["group archive <id> | unarchive <id>", "archive / unarchive"],
        ] },
      { icon: "📋", title: "Issue · task dispatch", desc: "task / collaborative issues, dispatch on create",
        cmds: [
          ["issue create <groupId> --description D [--title T] [--priority P] [--assignee A] [--run]", "create + optional immediate dispatch (--run requires --assignee)"],
          ["issue update <id> [--title T] [--description D] [--status S] [--assignee A|--unassign]", "partial field update"],
          ["issue cancel <id> | delete <id>", "cancel / delete"],
          ["issue list <groupId> [--status S] [--type task]", "list issues in group"],
          ["issue show <id> | events <id> | messages <id>", "details / timeline / related messages"],
          ["issue comment <id> --message M [--reply-to <eventId>]", "comment (can reply to specific event)"],
        ] },
      { icon: "🧠", title: "Memory · governance", desc: "note = human-only / memory = agent-visible; global goes through review",
        cmds: [
          ["memory add <groupId> --key K --value V --category C [--scope global] [--visibility V]", "add memory"],
          ["memory search <kw> <groupId> [--scope g|global] [--category C]", "keyword search"],
          ["memory list <groupId> [--scope global] [--type note|memory|all] [--tags t1,t2]", "list (with filters)"],
          ["memory promote <id> --visibility global", "promote to global (enters pendingReview)"],
          ["memory pending <groupId> [--scope global] | approve <id> | reject <id>", "review flow"],
          ["memory stats <groupId> [--scope global]", "memory stats"],
        ] },
      { icon: "🎯", title: "Skill / Schedule / Ask", desc: "skill dispatch + in-group timers + Q&A",
        cmds: [
          ["skill list <groupId> | bind <groupId> --skill S --agent A | unbind ...", "skill binding management"],
          ["schedule add --group <id> --mode agent|message --prompt P (--every D|--in D|--at ISO)", "create scheduled task"],
          ["schedule update <id> | enable <id> | disable <id> | trigger <id> | remove <id>", "schedule control"],
          ["ask <groupId> <target> <question...> [--timeout 5m] [--escalate-to <human>]", "ask + auto-create bridge"],
          ["ask list --group <id> [--status S] | show <id> | cancel <id>", "query / cancel Ask"],
        ] },
      { icon: "📦", title: "Repo · worktree cache", desc: "local FS operations; no agent needed",
        cmds: [
          ["repo list", "list bare clones under ~/.rotom/repos/ with worktree counts + disk usage"],
          ["repo prune [--remove-orphans]", "clean orphan worktree metadata; optionally delete unreferenced 30-day-stale bare clones"],
          ["repo fetch <repo-id> | remove <repo-id>", "explicit fetch / delete bare clone"],
        ] },
    ],
    footnote: `※ Full command doc in <code>src/cli/rotom.ts</code> top-level HELP; run <code>rotom help</code> to view it directly.`,
  },
}[lang];
---
<section class="section" id="cli-ref">
  <div class="wrap">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2>{t.h2}</h2>
    <p class="lead" set:html={t.lead} />

    <div class="cli-grid">
      {t.groups.map((g) => (
        <div class="card cli-card">
          <div class="card__icon">{g.icon}</div>
          <h3>{g.title}</h3>
          <p style="margin:0 0 12px;color:var(--text-mute);font-size:13px;">{g.desc}</p>
          <ul class="cli-list">
            {g.cmds.map((c) => (
              <li>
                <code class="cli-cmd">{c[0]}</code>
                <span class="cli-hint">{c[1]}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p style="margin-top:24px;color:var(--text-mute);font-size:13px;" set:html={t.footnote} />
  </div>
</section>
