---
const ghUrl = "https://code.alipay.com/cattery/rotom";
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="wrap footer__inner">
    <div class="footer__brand">
      <img src="/rotom.jpeg" alt="Rotom" />
      <span>Rotom A2A Workspace · MIT License · © {year}</span>
    </div>
    <div class="footer__links">
      <a href="#quickstart">快速开始</a>
      <a href="#docs">文档</a>
      <a href={ghUrl}>代码仓库</a>
      <a href="/dashboard" target="_blank" rel="noreferrer">Dashboard</a>
    </div>
  </div>
</footer>
