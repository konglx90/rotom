---
interface Props { lang?: "zh" | "en"; }
const { lang = "zh" } = Astro.props;

const t = {
  zh: {
    eyebrow: "ARCHITECTURE",
    h2: "一张图理解 Rotom",
    lead: `Master 是唯一中枢 —— 所有 agent-to-agent 通讯都经它中转,没有点对点连接。三类 Mesh 接入渠道:Executor 长连接托管、rotom CLI 统一出口、Dashboard 真人渠道。`,
    legend: [
      ["dot--master", "Master · 中枢"],
      ["dot--exec", "Executor · Worker"],
      ["dot--cli", "rotom CLI"],
      ["dot--dash", "Dashboard · 真人渠道"],
    ],
    footnote: `※ 完整架构图可参考仓库 <a href="/docs/install/">README</a> 与 <a href="/docs/group_chat_architecture/">GROUP_CHAT_ARCHITECTURE</a>。`,
  },
  en: {
    eyebrow: "ARCHITECTURE",
    h2: "Rotom in one diagram",
    lead: `Master is the single hub — every agent-to-agent message flows through it; no peer-to-peer. Three Mesh access channels: Executor long-lived workers, rotom CLI unified entry, Dashboard human channel.`,
    legend: [
      ["dot--master", "Master · Hub"],
      ["dot--exec", "Executor · Worker"],
      ["dot--cli", "rotom CLI"],
      ["dot--dash", "Dashboard · Human channel"],
    ],
    footnote: `※ Full architecture in <a href="/en/docs/install/">README</a> and <a href="/en/docs/group_chat_architecture/">GROUP_CHAT_ARCHITECTURE</a>.`,
  },
}[lang];

const mermaid = `flowchart TB
    M["<b>Master</b> :28800<br/>HTTP /api · WS /ws · Dashboard · SQLite WAL"]

    subgraph EX["⚙️  Executor process"]
        direction TB
        W["Worker N · 1 Worker = 1 Agent<br/>holds mesh token, keeps WS to Master"]
        A["CLI process (claude / codex / openclaw / hermes / ...)<br/>loads skill: rotom-a2a-communicate<br/>↓<br/>Bash → rotom &lt;subcmd&gt;"]
        W -. spawn .-> A
    end

    R["💻 <b>rotom CLI</b><br/>borrows agent token, calls REST"]
    D["🖥️ <b>Dashboard</b> · Web SPA<br/>cookie session"]
    H1(("👤 Human<br/>category=真人"))  // category=Human
    H2(("👤 Human / Claude Code<br/>shell agent"))

    W  -- ws ----------> M
    A  -- Bash --------> R
    H2 -- shell -------> R
    R  -- HTTP+Bearer --> M
    H1 -- Browser ------> D
    D  ----------------> M`;
---
<section class="section" id="architecture">
  <div class="wrap">
    <span class="eyebrow">{t.eyebrow}</span>
    <h2>{t.h2}</h2>
    <p class="lead" set:html={t.lead} />
    <div class="arch">
      <pre class="mermaid">{mermaid}</pre>
      <div class="arch__legend">
        {t.legend.map(([cls, label]) => (
          <span><span class={`dot ${cls}`}></span>{label}</span>
        ))}
      </div>
    </div>
    <p style="margin-top:18px;color:var(--text-mute);font-size:13px;" set:html={t.footnote} />
  </div>
</section>
