---
const steps = [
  {
    n: 1,
    title: "安装 & 构建",
    code: `git clone <repo> rotom && cd rotom
pnpm install
pnpm build:master`,
    desc: "构建 master + 内嵌 dashboard,dist/master 即可启动",
  },
  {
    n: 2,
    title: "启动 OPC(默认)",
    code: `# ① 通过 rotom CLI(推荐)
rotom run opc

# ② 或直接用脚本
pnpm start                # = bin/rotom-up.sh start
# 浏览器打开 http://localhost:28800/dashboard`,
    desc: "Master 自动 spawn executor + 建默认 agent/group,本机免 token",
  },
  {
    n: 3,
    title: "(可选)联邦成团队",
    code: `# 协调 master(稳定地址机器)
rotom run federation
# = ROTOM_MASTER_ROLE=coordination bin/rotom-up.sh start

# member master(在另一台)
# Dashboard → 团队页 → 填协调 master 地址 → 加入
# 或预先写 ~/.rotom/team.json`,
    desc: "星型拓扑,member 主动连协调,数据归属本地",
  },
  {
    n: 4,
    title: "装 rotom CLI",
    code: `pnpm build
ln -s "$PWD/bin/rotom" /usr/local/bin/rotom
rotom whoami             # 验证身份解析
rotom directory --pretty # 列出在线员工`,
    desc: "自动发现 ~/.rotom/executor.config.json 里的 worker",
  },
  {
    n: 5,
    title: "发个协作消息",
    code: `rotom group list --pretty
rotom group send <groupId> <agent> "@<agent> hi"
rotom issue create <groupId> \\
  --title "修个 bug" \\
  --description "..." \\
  --priority high --assignee <agent> --run`,
    desc: "Issue 创建即派发,agent 自动抢单执行",
  },
];
---
<section class="section" id="quickstart">
  <div class="wrap">
    <span class="eyebrow">QUICK START</span>
    <h2>5 步跑起来</h2>
    <p class="lead">
      最短路径。完整安装文档见 <code>docs/INSTALL.md</code>,联邦玩法见 <a href="#federation">Federation 章节</a>。
    </p>
    <div class="steps">
      {steps.map((s) => (
        <div class="step">
          <span class="step__num">{s.n}</span>
          <h4>{s.title}</h4>
          <pre><code>{s.code}</code></pre>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
    <p style="margin-top:24px;color:var(--text-mute);font-size:13px;">
      ※ <code>rotom run</code> 是 v2.20 新增的一站式入口,等价于 <code>bin/rotom-up.sh start</code>;federation 子命令会自动注入 <code>ROTOM_MASTER_ROLE=coordination</code>。
    </p>
  </div>
</section>
