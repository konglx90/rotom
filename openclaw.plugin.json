{
  "id": "a2a-gateway",
  "name": "Digital Employee Mesh",
  "description": "Enterprise agent collaboration network — connect digital employees via Master relay",
  "version": "2.0.0",
  "channels": [
    "a2a-gateway"
  ],
  "defaultConfig": {},
  "configSchema": {
    "type": "object",
    "properties": {
      "master": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ],
        "description": "Master WebSocket URL(s)"
      },
      "name": {
        "type": "string",
        "description": "Agent name"
      },
      "token": {
        "type": "string",
        "description": "Registration token"
      },
      "description": {
        "type": "string"
      },
      "filter": {
        "type": "object",
        "properties": {
          "allowFrom": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blockFrom": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "enabled": {
        "type": "boolean",
        "description": "Enable/disable the plugin",
        "default": true
      }
    }
  },
  "skills": [
    "skill/rotom-a2a-communicate"
  ],
  "uiHints": {
    "token": {
      "sensitive": true
    }
  }
}
